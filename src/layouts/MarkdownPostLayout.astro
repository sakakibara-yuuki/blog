---
import BaseLayout from './BaseLayout.astro';
const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
  <img src={frontmatter.image.url} width="80%" height="80%" alt={frontmatter.image.alt} />
  <p>pubDate: {frontmatter.pubDate.slice(0,10)}</p>
  <p>author: {frontmatter.author}</p>
  <div class="tags">
    {frontmatter.tags.map((tag) => (
      <p class="tag">
      <a href={`/tags/${tag}`}>{tag}</a>
      </p>
    ))}
  </div>
  <slot />
</BaseLayout>

<style>
  a {
    color: #00539F;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
  }

  .tag {
    margin: 0.25em;
    border: dotted 1px #a1a1a1;
    border-radius: .5em;
    padding: .5em 1em;
    font-size: 1.5em;
    background-color: #F8FCFD;
  }
</style>
